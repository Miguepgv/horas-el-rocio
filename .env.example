# Copia este archivo como `.env` en la raíz del proyecto y rellena los valores.
# Dónde están en Supabase: Dashboard → tu proyecto → Settings (rueda) → API

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Super admin: único correo que ve el engranaje para añadir más admins (coincide con app_config en SQL).
VITE_SUPER_ADMIN_EMAIL=mgomezlavado@yahoo.es

# Opcional: admins hasta ejecutar solo BD (coma separada).
VITE_ADMIN_EMAILS=

# Solo uso interno: login con correo sin contraseña ni magic link (requiere SQL que desactiva RLS).
# Tras editar .env: guardar (Ctrl+S) y reiniciar `npm run dev`, o Vite seguirá sin ver el cambio.
# VITE_INSECURE_EMAIL_LOGIN=true
# Alternativa: archivo vacío en la raíz llamado `insecure-login.flag` (mismo efecto que true arriba).

# Opcional (Android): URL HTTPS directa a tu archivo .apk (p. ej. GitHub Releases, Drive público, tu servidor).
# Genera el APK con PWABuilder, Bubblewrap o Android Studio; súbelo y pega aquí el enlace. En la app aparece «Descargar APK».
# VITE_ANDROID_APK_URL=https://ejemplo.com/horas-el-rocio.apk
